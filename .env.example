LLM_PROVIDER=openai
LLM_MODEL=gpt-4o-mini
LLM_API_KEY=
LLM_BASE_URL=

OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5
EMBEDDING_DIMENSIONS=384
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
QDRANT_PRODUCT_COLLECTION=btb_product_menu
QDRANT_MENU_ATTRIBUTES_COLLECTION=btb_menu_attributes
QDRANT_SUPPORT_COLLECTION=btb_company_policies
LOG_LEVEL=INFO
MEMORY_DATABASE_URL=sqlite+aiosqlite:///./data/memory/milo_memory.sqlite3
MEMORY_MAX_PROMPT_TOKENS=90000
MEMORY_KEEP_RECENT_MESSAGES=8
MEMORY_SUMMARY_CHECKPOINT_MESSAGES=8
MEMORY_SUMMARY_CACHE_TTL_SECONDS=1800
MEMORY_SUMMARY_CACHE_MAX_ENTRIES=1000
MEMORY_DB_POOL_SIZE=5
MEMORY_DB_MAX_OVERFLOW=10
MEMORY_DB_POOL_TIMEOUT=5
MEMORY_DB_POOL_RECYCLE=300
MEMORY_DB_POOL_PRE_PING=false
ORCHESTRATOR_MAX_ITERS=6
SPECIALIST_MAX_ITERS=4
SESSION_CACHE_MAX_SESSIONS=1000
SESSION_CACHE_TTL_SECONDS=1800

# For Neon production deployments, prefer the pooled "-pooler" URL here.
# Use the direct Neon connection string for Alembic migrations when required.
